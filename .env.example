# ─────────────────────────────────────────────────────────────
# Template for .env — copy to `.env` and fill in real values.
#   cp .env.example .env
#
# `.env` is gitignored and MUST NEVER be committed. This file is the
# only one that belongs in version control: it documents the keys
# without leaking their values.
#
# Precedence: dotenv does NOT override variables that already exist in
# the environment, so a real env var (e.g. a CI secret) always wins over
# whatever is written here. Set SHOPIFY_STOREFRONT_PASSWORD as a masked
# CI secret rather than committing it anywhere.
# ─────────────────────────────────────────────────────────────

# Storefront under test. No trailing slash.
SHOPIFY_BASE_URL=https://your-store.myshopify.com

# Storefront password (Shopify Admin → Online Store → Preferences →
# Password protection). Required for password-protected stores — every
# Development-plan store is one. Leave EMPTY for open storefronts.
#
# Consumed only by scripts/allure-global-setup.ts, which converts it to a
# `storefront_digest` cookie. It is never typed into a form, so it cannot
# leak into Playwright traces, videos, or screenshots.
SHOPIFY_STOREFRONT_PASSWORD=

# Optional: render a specific UNPUBLISHED/DEMO theme without publishing it
# (Shopify's `?preview_theme_id=` preview). Leave EMPTY to use the
# currently published (MAIN) theme.
SHOPIFY_PREVIEW_THEME_ID=
